{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Voxa",
  "version": "0.1.0",
  "identifier": "app.voxa.desktop",
  "build": {
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "pnpm --filter @voxa/web build",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Voxa",
        "width": 1240,
        "height": 800,
        "minWidth": 940,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
