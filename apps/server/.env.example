# Локальная разработка apps/server (скопируй в apps/server/.env).
# Значения совпадают с docker-compose.dev.yml.
DATABASE_URL=postgresql://voxa:voxa@localhost:5433/voxa
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=dev-access-secret-not-for-prod
JWT_REFRESH_SECRET=dev-refresh-secret-not-for-prod
PUBLIC_URL=http://localhost:3000
# Разрешённый origin веб-клиента в dev (CORS); в проде не нужен (same-origin)
WEB_ORIGIN=http://localhost:5173
PORT=3000

# S3 (MinIO): значения по умолчанию совпадают с docker-compose.dev.yml,
# в dev можно не задавать.
# S3_ENDPOINT=http://localhost:9000
# S3_ACCESS_KEY=voxa
# S3_SECRET_KEY=voxa-dev-minio
# S3_BUCKET=voxa-files
# PUBLIC_S3_ENDPOINT=   # прод: https://files.домен — для подписанных ссылок
# MAX_UPLOAD_MB=50
# USER_QUOTA_MB=2048
