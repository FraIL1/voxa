# Локальная разработка apps/server (скопируй в apps/server/.env).
# Значения совпадают с docker-compose.dev.yml.
DATABASE_URL=postgresql://voxa:voxa@localhost:5433/voxa
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=dev-access-secret-not-for-prod
JWT_REFRESH_SECRET=dev-refresh-secret-not-for-prod
PUBLIC_URL=http://localhost:3000
# Разрешённый origin веб-клиента в dev (CORS); в проде не нужен (same-origin)
WEB_ORIGIN=http://localhost:5173
PORT=3000
