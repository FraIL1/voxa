generator client {
  provider      = "prisma-client-js"
  // native — локальная разработка; musl — рантайм в node:22-alpine
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid(7))
  /// Неизменяемый уникальный логин (регистрация, вход, заявки в друзья)
  username      String
  usernameLower String    @unique @map("username_lower")
  /// Отображаемое имя — можно менять свободно
  displayName   String    @map("display_name")
  passwordHash  String    @map("password_hash")
  avatarUrl     String?   @map("avatar_url")
  /// Таймаут: до этого момента не может писать и говорить (раздел 5.10 PRD)
  timedOutUntil DateTime? @map("timed_out_until")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  roles            UserRole[]
  sessions         RefreshSession[]
  messages         Message[]
  reactions        Reaction[]
  readStates       ChannelReadState[]
  attachments      Attachment[]
  invitesCreated   Invite[]           @relation("InviteCreator")
  bansReceived     Ban[]              @relation("BannedUser")
  bansIssued       Ban[]              @relation("BanIssuer")
  auditActions     AuditLog[]         @relation("AuditActor")
  guildsOwned      Guild[]            @relation("GuildOwner")
  guildMemberships GuildMember[]
  dmAsUserA        DmConversation[]   @relation("DmUserA")
  dmAsUserB        DmConversation[]   @relation("DmUserB")
  dmMessages       DmMessage[]
  dmReadStates     DmReadState[]
  friendsSent      Friendship[]       @relation("FriendRequester")
  friendsReceived  Friendship[]       @relation("FriendAddressee")
  blocksMade       UserBlock[]        @relation("Blocker")
  blocksReceived   UserBlock[]        @relation("Blocked")

  @@map("users")
}

/// Сервер (guild): отдельное пространство с каналами, ролями и участниками
model Guild {
  id        String   @id @default(uuid(7))
  name      String
  iconUrl   String?  @map("icon_url")
  ownerId   String?  @map("owner_id")
  owner     User?    @relation("GuildOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members    GuildMember[]
  categories Category[]
  channels   Channel[]
  roles      Role[]
  invites    Invite[]
  bans       Ban[]

  @@map("guilds")
}

/// Членство пользователя на сервере
model GuildMember {
  guildId  String   @map("guild_id")
  guild    Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  userId   String   @map("user_id")
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Ник на этом сервере; null — используется displayName
  nickname String?
  joinedAt DateTime @default(now()) @map("joined_at")

  @@id([guildId, userId])
  @@index([userId])
  @@map("guild_members")
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
}

/// Дружба или заявка: одна строка на пару, направление — кто отправил заявку
model Friendship {
  id          String           @id @default(uuid(7))
  requesterId String           @map("requester_id")
  requester   User             @relation("FriendRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addresseeId String           @map("addressee_id")
  addressee   User             @relation("FriendAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@unique([requesterId, addresseeId])
  @@index([addresseeId])
  @@map("friendships")
}

/// Односторонняя блокировка: закрывает ЛС и заявки в обе стороны
model UserBlock {
  blockerId String   @map("blocker_id")
  blocker   User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId String   @map("blocked_id")
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@id([blockerId, blockedId])
  @@map("user_blocks")
}

/// Бан на сервере: участник удалён и не может зайти по инвайту до разбана
model Ban {
  guildId    String   @map("guild_id")
  guild      Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  userId     String   @map("user_id")
  user       User     @relation("BannedUser", fields: [userId], references: [id], onDelete: Cascade)
  reason     String?
  bannedById String?  @map("banned_by_id")
  bannedBy   User?    @relation("BanIssuer", fields: [bannedById], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now()) @map("created_at")

  @@id([guildId, userId])
  @@map("bans")
}

/// Журнал аудита: кто что сделал (раздел 5.10 PRD)
model AuditLog {
  id         BigInt   @id @default(autoincrement())
  /// null — действие уровня инстанса (не привязано к серверу)
  guildId    String?  @map("guild_id")
  actorId    String?  @map("actor_id")
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  /// user.kick / user.ban / channel.create / invite.revoke / message.delete.other ...
  action     String
  targetType String?  @map("target_type")
  targetId   String?  @map("target_id")
  meta       Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("audit_log")
}

model Invite {
  id           String    @id @default(uuid(7))
  code         String    @unique
  guildId      String    @map("guild_id")
  guild        Guild     @relation(fields: [guildId], references: [id], onDelete: Cascade)
  createdById  String?   @map("created_by_id")
  createdBy    User?     @relation("InviteCreator", fields: [createdById], references: [id], onDelete: SetNull)
  /// Роль, которая выдаётся при регистрации по этому инвайту (bootstrap Владельца)
  grantsRoleId String?   @map("grants_role_id")
  grantsRole   Role?     @relation(fields: [grantsRoleId], references: [id], onDelete: SetNull)
  maxUses      Int?      @map("max_uses")
  uses         Int       @default(0)
  expiresAt    DateTime? @map("expires_at")
  revokedAt    DateTime? @map("revoked_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@map("invites")
}

model RefreshSession {
  id        String    @id @default(uuid(7))
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// HMAC-SHA256 от refresh-токена (сам токен нигде не хранится)
  tokenHash String    @unique @map("token_hash")
  /// Семейство ротации: при повторном использовании старого токена
  /// отзывается вся цепочка (детекция кражи)
  family    String
  userAgent String?   @map("user_agent")
  ip        String?
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([family])
  @@map("refresh_sessions")
}

model LoginAttempt {
  id        BigInt   @id @default(autoincrement())
  username  String
  ip        String
  success   Boolean
  createdAt DateTime @default(now()) @map("created_at")

  @@index([username, createdAt])
  @@map("login_attempts")
}

model Role {
  id          String   @id @default(uuid(7))
  guildId     String   @map("guild_id")
  guild       Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  name        String
  color       String?
  /// Битмаска прав (см. Permissions в @voxa/shared)
  permissions Int
  /// Больше — старше в иерархии
  position    Int
  /// Выдаётся автоматически при регистрации («Участник»)
  isDefault   Boolean  @default(false) @map("is_default")
  /// «Владелец»: все права, роль нельзя удалить
  isOwnerRole Boolean  @default(false) @map("is_owner_role")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  members       UserRole[]
  channelAccess ChannelRoleAccess[]
  invites       Invite[]

  @@unique([guildId, name])
  @@map("roles")
}

model UserRole {
  userId String @map("user_id")
  roleId String @map("role_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model Category {
  id        String    @id @default(uuid(7))
  guildId   String    @map("guild_id")
  guild     Guild     @relation(fields: [guildId], references: [id], onDelete: Cascade)
  name      String
  position  Int
  createdAt DateTime  @default(now()) @map("created_at")
  channels  Channel[]

  @@index([guildId])
  @@map("categories")
}

enum ChannelType {
  TEXT
  VOICE
}

model Channel {
  id         String      @id @default(uuid(7))
  guildId    String      @map("guild_id")
  guild      Guild       @relation(fields: [guildId], references: [id], onDelete: Cascade)
  name       String
  type       ChannelType
  topic      String?
  categoryId String?     @map("category_id")
  category   Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  position   Int
  isPrivate  Boolean     @default(false) @map("is_private")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  allowedRoles ChannelRoleAccess[]
  messages     Message[]
  readStates   ChannelReadState[]

  @@index([guildId])
  @@map("channels")
}

model ChannelRoleAccess {
  channelId String  @map("channel_id")
  roleId    String  @map("role_id")
  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  role      Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([channelId, roleId])
  @@map("channel_role_access")
}

model Message {
  id        String    @id @default(uuid(7))
  channelId String    @map("channel_id")
  channel   Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  authorId  String?   @map("author_id")
  author    User?     @relation(fields: [authorId], references: [id], onDelete: SetNull)
  /// Markdown-исходник; санитизация — при рендере на клиенте
  content   String
  replyToId String?   @map("reply_to_id")
  replyTo   Message?  @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   Message[] @relation("MessageReplies")
  editedAt  DateTime? @map("edited_at")
  /// Мягкое удаление: ответы на удалённое сообщение показывают заглушку
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")

  /// Предпросмотр первой ссылки (LinkPreviewDto); заполняется асинхронно
  linkPreview Json? @map("link_preview")

  reactions   Reaction[]
  attachments Attachment[]

  @@index([channelId, createdAt])
  @@map("messages")
}

/// Файл в MinIO; привязывается к сообщению при отправке
model Attachment {
  id          String     @id @default(uuid(7))
  uploaderId  String?    @map("uploader_id")
  uploader    User?      @relation(fields: [uploaderId], references: [id], onDelete: SetNull)
  messageId   String?    @map("message_id")
  message     Message?   @relation(fields: [messageId], references: [id], onDelete: Cascade)
  /// Привязка к личному сообщению (взаимоисключающе с messageId)
  dmMessageId String?    @map("dm_message_id")
  dmMessage   DmMessage? @relation(fields: [dmMessageId], references: [id], onDelete: Cascade)

  /// Ключ объекта в бакете
  key         String  @unique
  /// Ключ миниатюры (только изображения)
  thumbKey    String? @map("thumb_key")
  fileName    String  @map("file_name")
  contentType String  @map("content_type")
  size        Int
  width       Int?
  height      Int?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([uploaderId])
  @@index([messageId])
  @@index([dmMessageId])
  @@map("attachments")
}

/// Диалог 1-на-1 (раздел 5.6 PRD). Пара упорядочена (userAId < userBId),
/// поэтому на двух пользователей — ровно одна строка.
model DmConversation {
  id            String   @id @default(uuid(7))
  userAId       String   @map("user_a_id")
  userBId       String   @map("user_b_id")
  userA         User     @relation("DmUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB         User     @relation("DmUserB", fields: [userBId], references: [id], onDelete: Cascade)
  /// Для сортировки списка диалогов по свежести
  lastMessageAt DateTime @default(now()) @map("last_message_at")
  createdAt     DateTime @default(now()) @map("created_at")

  messages   DmMessage[]
  readStates DmReadState[]

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
  @@map("dm_conversations")
}

model DmMessage {
  id             String         @id @default(uuid(7))
  conversationId String         @map("conversation_id")
  conversation   DmConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  authorId       String?        @map("author_id")
  author         User?          @relation(fields: [authorId], references: [id], onDelete: SetNull)
  content        String
  replyToId      String?        @map("reply_to_id")
  replyTo        DmMessage?     @relation("DmReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies        DmMessage[]    @relation("DmReplies")
  editedAt       DateTime?      @map("edited_at")
  deletedAt      DateTime?      @map("deleted_at")
  createdAt      DateTime       @default(now()) @map("created_at")

  attachments Attachment[]

  @@index([conversationId, id])
  @@map("dm_messages")
}

/// Прочитанность диалога участником
model DmReadState {
  conversationId    String         @map("conversation_id")
  conversation      DmConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId            String         @map("user_id")
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadMessageId String?        @map("last_read_message_id")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  @@id([conversationId, userId])
  @@map("dm_read_states")
}

model Reaction {
  id        String   @id @default(uuid(7))
  messageId String   @map("message_id")
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Эмодзи как есть (может быть несколько кодпоинтов)
  emoji     String
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@map("reactions")
}

/// Прочитанность канала пользователем: маркер и счётчик упоминаний
model ChannelReadState {
  userId            String   @map("user_id")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channelId         String   @map("channel_id")
  channel           Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  /// id последнего прочитанного сообщения (uuid v7 — монотонен)
  lastReadMessageId String?  @map("last_read_message_id")
  mentionCount      Int      @default(0) @map("mention_count")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@id([userId, channelId])
  @@map("channel_read_states")
}

/// Служебные флаги приложения (выполнен ли стартовый сид и т.п.)
model AppMeta {
  key   String @id
  value String

  @@map("app_meta")
}
