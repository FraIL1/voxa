# ==== Voxa: конфигурация прод-развёртывания (docker-compose.yml) ====
# 1. Скопируй файл:            cp .env.example .env
# 2. Сгенерируй каждый секрет: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# .env в git не попадает (см. .gitignore).

# Домен, на который Caddy автоматически получит TLS-сертификат (Let's Encrypt).
# Для локальной проверки прод-стека оставь localhost — Caddy выпустит self-signed.
DOMAIN=localhost

# PostgreSQL
POSTGRES_PASSWORD=CHANGE_ME

# MinIO (S3-хранилище файлов)
MINIO_ROOT_USER=voxa
MINIO_ROOT_PASSWORD=CHANGE_ME

# JWT (этап 1) — два РАЗНЫХ случайных секрета
JWT_ACCESS_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME
